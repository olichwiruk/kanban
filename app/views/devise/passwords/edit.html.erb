<div class="hero">
  <div class="hero-content flex-col">
    <div class="card flex-shrink-0 w-full max-w-sm shadow-2xl">
      <div class="card-body">
        <h2 class="card-title text-2xl font-bold text-center">Change your password</h2>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>
          <%= f.hidden_field :reset_password_token %>

          <div class="form-control">
            <%= f.label :password, "New password", class: "label" %>
            <% if @minimum_password_length %>
              <span class="label-text-alt mb-1">(<%= @minimum_password_length %> characters minimum)</span>
            <% end %>
            <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "input input-bordered w-full" %>
          </div>

          <div class="form-control">
            <%= f.label :password_confirmation, "Confirm new password", class: "label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered w-full" %>
          </div>

          <div class="form-control mt-6">
            <%= f.submit "Change my password", class: "btn btn-primary w-full" %>
          </div>
        <% end %>

        <div class="divider">OR</div>

        <div class="text-center">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
