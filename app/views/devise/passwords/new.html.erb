<div class="hero">
  <div class="hero-content flex-col">
    <div class="card flex-shrink-0 w-full max-w-sm shadow-2xl">
      <div class="card-body">
        <h2 class="text-2xl font-bold text-center">Forgot your password?</h2>
        <p class="text-sm text-center text-base-content/70 mb-4">
          Enter your email address and we'll send you instructions to reset your password.
        </p>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="form-control">
            <%= f.label :email, class: "label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
          </div>

          <div class="form-control mt-6">
            <%= f.submit "Send reset instructions", class: "btn btn-primary w-full" %>
          </div>
        <% end %>

        <div class="divider">OR</div>

        <div class="text-center">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
